# Exemplo de .env para DESENVOLVIMENTO
# Copie este arquivo para .env e preencha com valores reais

# ============================================
# DJANGO SETTINGS
# ============================================
SECRET_KEY=dev-secret-key-not-for-production-12345678901234567890
DEBUG=False
ALLOWED_HOSTS=seu-dominio-dev.com,IP_DO_SERVIDOR_DEV,localhost

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_NAME=crm_solar_dev
DB_USER=postgres
DB_PASSWORD=senha-dev-forte-aqui
DB_HOST=db
DB_PORT=5432

# ============================================
# REDIS (Cache/Sessions)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# CORS (Frontend URLs permitidas)
# ============================================
CORS_ORIGINS=http://seu-dominio-dev.com,http://localhost:5173

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://seu-dominio-dev.com

# ============================================
# DOCKER/GITHUB (para CI/CD)
# ============================================
GITHUB_REPOSITORY=seu-usuario/SunOps---SaaS
IMAGE_TAG=dev-latest

# ============================================
# APIs EXTERNAS (Opcional)
# ============================================

# Google Maps (para cálculo de deslocamento)
GOOGLE_MAPS_API_KEY=

# IA APIs (para funcionalidades de IA)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# DESENVOLVIMENTO
# ============================================
# Pode usar valores de teste aqui
# Não precisa de SSL/HSTS em DEV
