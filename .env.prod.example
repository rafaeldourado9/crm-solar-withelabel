# Exemplo de .env para PRODUÇÃO
# Copie este arquivo para .env e preencha com valores reais

# ============================================
# DJANGO SETTINGS
# ============================================
SECRET_KEY=CHANGE-THIS-TO-A-VERY-LONG-RANDOM-STRING-min-50-chars
DEBUG=False
ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com,IP_DO_SERVIDOR

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_NAME=crm_solar
DB_USER=postgres
DB_PASSWORD=SENHA-SUPER-FORTE-AQUI-min-20-chars
DB_HOST=db
DB_PORT=5432

# ============================================
# REDIS (Cache/Sessions)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# CORS (Frontend URLs permitidas)
# ============================================
CORS_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=https://seu-dominio.com

# ============================================
# DOCKER/GITHUB (para CI/CD)
# ============================================
GITHUB_REPOSITORY=seu-usuario/SunOps---SaaS
IMAGE_TAG=prod-latest

# ============================================
# APIs EXTERNAS (Opcional)
# ============================================

# Google Maps (para cálculo de deslocamento)
GOOGLE_MAPS_API_KEY=

# IA APIs (para funcionalidades de IA)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# SEGURANÇA (Opcional mas recomendado)
# ============================================

# SSL/TLS
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HSTS
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ============================================
# EMAIL (Opcional - para notificações)
# ============================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=seu-email@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app

# ============================================
# BACKUP (Opcional)
# ============================================
# BACKUP_RETENTION_DAYS=7
# BACKUP_S3_BUCKET=seu-bucket-s3

# ============================================
# MONITORING (Opcional)
# ============================================
# SENTRY_DSN=https://...
# SENTRY_ENVIRONMENT=production

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA commite este arquivo com valores reais
# 2. Use senhas fortes (mínimo 20 caracteres)
# 3. Gere SECRET_KEY com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 4. Mantenha backup deste arquivo em local seguro
# 5. Rotacione senhas periodicamente
